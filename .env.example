# Chain selection — must match a file in config/chains/<chain>.json
CHAIN=base

# RPC endpoints (primary + comma-separated fallbacks)
RPC_URL=
RPC_URL_FALLBACK=

# Optional API keys
ZEROEX_API_KEY=
BASESCAN_API_KEY=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Per-type live message toggles. Each event still counts toward the batch summary
# below regardless of these flags. Defaults shown.
TELEGRAM_NOTIFY_TRADES=true
TELEGRAM_NOTIFY_APPROVES=false
TELEGRAM_NOTIFY_ERRORS=true

# Periodic batch summary: total trades / approves / errors in the window.
# Minutes between summaries. 0 = disabled. Recommended 15-60 for daily operation.
TELEGRAM_BATCH_SUMMARY_MIN=0

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# Storage
DB_PATH=./data/wallet-ager.db

# Wallet & token config paths (override the defaults)
WALLETS_CONFIG=./config/wallets.json
TOKENS_CONFIG=./config/tokens.json

# Runtime
DRY_RUN=false
MAX_CONCURRENCY=10

# Discovery (Virtuals + Uniswap V2/V3/V4 + Bankr/Doppler listeners)
# How often the sweeper re-runs safety on active discovered tokens (hours).
# Set to 0 to disable.
DISCOVERY_RECHECK_HOURS=6
# Discovered tokens with no trades in this window get evicted (hours).
DISCOVERY_TTL_HOURS=48

# Safety provider for non-Virtuals tokens:
#   simulation — on-chain quote + eth_call roundtrip (covers V2/V3/V4)  [default]
#   honeypot   — external honeypot.is API (legacy, gaps on V4)
SAFETY_PROVIDER=simulation

# Sniper fanout — N random eligible wallets snipe each fresh launch, staggered by random
# delay in [min, max] ms. Universal across all discovery sources. Defaults (1 + 0-0) preserve
# single-wallet immediate behavior. Per-wallet cooldown prevents the same wallet being picked
# in back-to-back discoveries even across different launchpads.
#
# Cap notes: each fired wallet consumes 1 daily slot. Fanout=5 × 50 disc/day = 250 buys/day
# spread across the wallet pool. Make sure profile.tradesPerDay supports the load.
# Pattern notes: stagger spreads buys across blocks → wallets look like independent users
# discovering the launch at different times. Lower stagger = more pattern-detectable.
SNIPER_FANOUT=5
SNIPER_FANOUT_STAGGER_MS=1000-4000

# Sniper sell retry window for Clanker tokens (v13.18). The Clanker MEV hook has a
# time-based anti-snipe window — forensic n=93 shows P50=2.1min, P99=3.0min from
# discovery to first successful UR sell. Default retry config (5 × 30s = 2.5min)
# barely covers the median; these overrides extend to 10 × 1min = 10min total,
# covering P99 with ~3× headroom. Apply ONLY to /^clanker-/ source tokens.
SNIPER_CLANKER_SELL_RETRY_INTERVAL_MS=60000
SNIPER_CLANKER_SELL_MAX_ATTEMPTS=10
